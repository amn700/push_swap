{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with Makefile",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/push_swap",  // Replace "program" with the output of your Makefile
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/Users/mohchaib/goinfre/homebrew/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build"
        }
    ]
}
